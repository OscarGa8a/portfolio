---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import Section from './Section.astro';

interface Props { lang: Locale; }
const { lang } = Astro.props;
---
<Section id="especialidades" padding="py-24">
  <div class="max-w-3xl mb-16">
    <h2 class="font-sora text-3xl md:text-4xl font-bold mb-6 text-white">{t(lang, 'services_title')}</h2>
    <p class="text-text-sec text-lg leading-relaxed">{t(lang, 'services_subtitle')}</p>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <!-- Web -->
    <div class="premium-card p-8 rounded-2xl group flex flex-col h-full">
      <div class="w-12 h-12 rounded-xl bg-acc-blue/10 flex items-center justify-center mb-6 text-acc-blue group-hover:bg-acc-blue/20 transition-all">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
      </div>
      <h3 class="font-sora text-xl font-bold mb-3 text-white">{t(lang, 'services_web_title')}</h3>
      <p class="text-text-sec text-sm mb-6 flex-1">{t(lang, 'services_web_desc')}</p>
      <ul class="space-y-2 text-sm text-text-sec/90 border-t border-white/5 pt-4">
        <li class="flex items-start gap-2"><span class="text-acc-blue">✓</span> {t(lang, 'services_web_f1')}</li>
        <li class="flex items-start gap-2"><span class="text-acc-blue">✓</span> {t(lang, 'services_web_f2')}</li>
        <li class="flex items-start gap-2"><span class="text-acc-blue">✓</span> {t(lang, 'services_web_f3')}</li>
      </ul>
    </div>

    <!-- E-commerce -->
    <div class="premium-card p-8 rounded-2xl group flex flex-col h-full">
      <div class="w-12 h-12 rounded-xl bg-acc-violet/10 flex items-center justify-center mb-6 text-acc-violet group-hover:bg-acc-violet/20 transition-all">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
      </div>
      <h3 class="font-sora text-xl font-bold mb-3 text-white">{t(lang, 'services_ecom_title')}</h3>
      <p class="text-text-sec text-sm mb-6 flex-1">{t(lang, 'services_ecom_desc')}</p>
      <ul class="space-y-2 text-sm text-text-sec/90 border-t border-white/5 pt-4">
        <li class="flex items-start gap-2"><span class="text-acc-violet">✓</span> {t(lang, 'services_ecom_f1')}</li>
        <li class="flex items-start gap-2"><span class="text-acc-violet">✓</span> {t(lang, 'services_ecom_f2')}</li>
        <li class="flex items-start gap-2"><span class="text-acc-violet">✓</span> {t(lang, 'services_ecom_f3')}</li>
      </ul>
    </div>

    <!-- Apps -->
    <div class="premium-card p-8 rounded-2xl group flex flex-col h-full">
      <div class="w-12 h-12 rounded-xl bg-acc-cyan/10 flex items-center justify-center mb-6 text-acc-cyan group-hover:bg-acc-cyan/20 transition-all">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
      </div>
      <h3 class="font-sora text-xl font-bold mb-3 text-white">{t(lang, 'services_app_title')}</h3>
      <p class="text-text-sec text-sm mb-6 flex-1">{t(lang, 'services_app_desc')}</p>
      <ul class="space-y-2 text-sm text-text-sec/90 border-t border-white/5 pt-4">
        <li class="flex items-start gap-2"><span class="text-acc-cyan">✓</span> {t(lang, 'services_app_f1')}</li>
        <li class="flex items-start gap-2"><span class="text-acc-cyan">✓</span> {t(lang, 'services_app_f2')}</li>
        <li class="flex items-start gap-2"><span class="text-acc-cyan">✓</span> {t(lang, 'services_app_f3')}</li>
      </ul>
    </div>

    <!-- Platforms -->
    <div class="premium-card p-8 rounded-2xl group flex flex-col h-full">
      <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-6 text-white group-hover:bg-white/20 transition-all">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
      </div>
      <h3 class="font-sora text-xl font-bold mb-3 text-white">{t(lang, 'services_platform_title')}</h3>
      <p class="text-text-sec text-sm mb-6 flex-1">{t(lang, 'services_platform_desc')}</p>
      <ul class="space-y-2 text-sm text-text-sec/90 border-t border-white/5 pt-4">
        <li class="flex items-start gap-2"><span class="text-white/80">✓</span> {t(lang, 'services_platform_f1')}</li>
        <li class="flex items-start gap-2"><span class="text-white/80">✓</span> {t(lang, 'services_platform_f2')}</li>
        <li class="flex items-start gap-2"><span class="text-white/80">✓</span> {t(lang, 'services_platform_f3')}</li>
      </ul>
    </div>
  </div>
</Section>
