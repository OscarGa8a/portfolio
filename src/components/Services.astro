---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import { Icon } from 'astro-icon/components';
import Section from './Section.astro';

interface Props { lang: Locale; }
const { lang } = Astro.props;

const services = [
  {
    icon: 'ph:browser',
    title: 'services_web_title',
    desc: 'services_web_desc',
    features: ['services_web_f1', 'services_web_f2', 'services_web_f3'],
  },
  {
    icon: 'ph:shopping-bag-open',
    title: 'services_ecom_title',
    desc: 'services_ecom_desc',
    features: ['services_ecom_f1', 'services_ecom_f2', 'services_ecom_f3'],
  },
  {
    icon: 'ph:device-mobile',
    title: 'services_app_title',
    desc: 'services_app_desc',
    features: ['services_app_f1', 'services_app_f2', 'services_app_f3'],
  },
  {
    icon: 'ph:squares-four',
    title: 'services_platform_title',
    desc: 'services_platform_desc',
    features: ['services_platform_f1', 'services_platform_f2', 'services_platform_f3'],
  },
];
---
<Section id="especialidades" padding="py-24">
  <div class="max-w-3xl mb-16">
    <h2 class="font-display text-3xl md:text-4xl font-bold mb-5 text-text-main">{t(lang, 'services_title')}</h2>
    <p class="text-text-sec text-lg leading-relaxed">{t(lang, 'services_subtitle')}</p>
  </div>

  <!-- Open editorial grid: hairline dividers, no boxes -->
  <div class="grid md:grid-cols-2 gap-x-16 gap-y-14">
    {services.map((s) => (
      <div class="border-t border-white/10 pt-7">
        <div class="flex items-center gap-3 mb-4">
          <Icon name={s.icon} class="w-7 h-7 text-accent" />
          <h3 class="font-display text-xl font-bold text-text-main">{t(lang, s.title)}</h3>
        </div>
        <p class="text-text-sec leading-relaxed mb-5 max-w-md">{t(lang, s.desc)}</p>
        <ul class="flex flex-col gap-2.5">
          {s.features.map((f) => (
            <li class="flex items-center gap-2.5 text-sm text-text-sec">
              <Icon name="ph:check" class="w-4 h-4 text-accent shrink-0" />
              {t(lang, f)}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</Section>
