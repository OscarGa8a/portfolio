---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import { Image } from 'astro:assets';
import duartes from '../assets/projects/duartes.png';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
---
<section class="relative min-h-[100dvh] pt-24 pb-16 px-6 lg:px-8 max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
  <!-- Left: Content -->
  <div class="lg:w-1/2 flex flex-col items-start space-y-7 reveal">
    <!-- Availability badge (the dot conveys real status: open for work) -->
    <div class="inline-flex items-center gap-2 bg-card-bg border border-white/10 rounded-full px-4 py-2 text-xs font-medium text-accent">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
      </span>
      <span>{t(lang, 'hero_badge')}</span>
    </div>

    <!-- Headline -->
    <h1 class="font-display font-bold text-4xl md:text-5xl leading-[1.1] tracking-tight text-text-main max-w-xl">
      {t(lang, 'hero_title_1')} <span class="text-gradient">{t(lang, 'hero_title_gradient')}</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg text-text-sec leading-relaxed max-w-xl">
      {t(lang, 'hero_subtitle')}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 w-full sm:w-auto pt-2">
      <a href="#casos" class="text-center bg-accent text-bg-main px-7 py-3.5 rounded-xl font-semibold hover:bg-accent-strong transition-colors active:translate-y-px">
        {t(lang, 'hero_cta_primary')}
      </a>
      <a href="#contacto" class="text-center border border-white/15 px-7 py-3.5 rounded-xl font-semibold text-text-main hover:border-white/30 hover:bg-white/5 transition-colors active:translate-y-px">
        {t(lang, 'hero_cta_secondary')}
      </a>
    </div>
  </div>

  <div class="hidden lg:flex lg:w-1/2 relative w-full h-[420px] lg:h-[560px] items-center justify-center reveal">
  <!-- Right: Project preview -->
  <div class="lg:w-1/2 relative w-full flex items-center justify-center reveal">
    <!-- Static accent glow for depth (single accent, no pulse) -->
    <div class="absolute inset-8 bg-accent/10 blur-[90px] rounded-full pointer-events-none -z-10"></div>

    <Image
      src={duartes}
      alt={lang === 'es' ? "Duarte's Auto Detailing — landing de detailing premium a domicilio" : "Duarte's Auto Detailing — premium mobile detailing landing"}
      class="w-full aspect-[4/3] object-cover object-top rounded-2xl border border-white/10 shadow-2xl animate-float"
      loading="eager"
    />
  </div>

</section>
