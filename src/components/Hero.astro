---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
---
<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 px-6 lg:px-8 max-w-7xl mx-auto flex flex-col-reverse lg:flex-row items-center gap-12 lg:gap-20 min-h-[90vh]">
  <!-- Left: Content -->
  <div class="lg:w-1/2 flex flex-col items-start space-y-8 reveal">
    <!-- Badge -->
    <div class="inline-flex items-center space-x-2 bg-card-bg border border-white/10 rounded-full px-4 py-2 text-xs font-medium text-acc-cyan">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-acc-cyan opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-acc-cyan"></span>
      </span>
      <span>{t(lang, 'hero_badge')}</span>
    </div>

    <!-- Headline -->
    <h1 class="font-sora font-bold text-4xl lg:text-5xl leading-[1.15] tracking-tight max-w-2xl text-white">
      {t(lang, 'hero_title_1')} <span class="text-gradient">{t(lang, 'hero_title_gradient')}</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg text-text-sec leading-relaxed max-w-xl">
      {t(lang, 'hero_subtitle')}
    </p>

    <!-- Supporting line -->
    <div class="border-l-2 border-acc-violet/50 pl-4 text-sm text-text-sec/80 max-w-lg">
      {t(lang, 'hero_supporting')}
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto pt-2">
      <a href="#casos" class="w-full sm:w-auto text-center bg-white text-bg-main px-8 py-3.5 rounded-xl font-semibold hover:bg-gray-200 transition-all shadow-[0_0_20px_rgba(255,255,255,0.1)]">
        {t(lang, 'hero_cta_primary')}
      </a>
      <a href="#contacto" class="w-full sm:w-auto text-center premium-card px-8 py-3.5 rounded-xl font-semibold text-white">
        {t(lang, 'hero_cta_secondary')}
      </a>
    </div>

    <!-- Trust chips -->
    <div class="flex flex-wrap gap-2.5 pt-4">
      <span class="text-[11px] uppercase tracking-wider font-semibold bg-bg-sec border border-white/5 px-3 py-1.5 rounded-md text-text-sec flex items-center gap-1.5"><span class="text-acc-blue">✓</span> {t(lang, 'hero_chip_experience')}</span>
      <span class="text-[11px] uppercase tracking-wider font-semibold bg-bg-sec border border-white/5 px-3 py-1.5 rounded-md text-text-sec flex items-center gap-1.5"><span class="text-acc-violet">✓</span> {t(lang, 'hero_chip_apps')}</span>
      <span class="text-[11px] uppercase tracking-wider font-semibold bg-bg-sec border border-white/5 px-3 py-1.5 rounded-md text-text-sec flex items-center gap-1.5"><span class="text-acc-cyan">✓</span> {t(lang, 'hero_chip_ecommerce')}</span>
      <span class="text-[11px] uppercase tracking-wider font-semibold bg-bg-sec border border-white/5 px-3 py-1.5 rounded-md text-text-sec flex items-center gap-1.5"><span class="text-acc-blue">✓</span> {t(lang, 'hero_chip_platforms')}</span>
      <span class="text-[11px] uppercase tracking-wider font-semibold bg-bg-sec border border-white/5 px-3 py-1.5 rounded-md text-text-sec flex items-center gap-1.5"><span class="text-acc-violet">✓</span> {t(lang, 'hero_chip_responsive')}</span>
    </div>
  </div>

  <!-- Right: Visual composition -->
  <div class="lg:w-1/2 relative w-full h-[400px] lg:h-[500px] flex items-center justify-center reveal">
    <!-- Dashboard mockup -->
    <div class="absolute w-[90%] h-[280px] premium-card rounded-xl p-2 z-10 shadow-2xl animate-float">
      <div class="w-full h-full bg-bg-main rounded-lg border border-white/5 overflow-hidden flex flex-col relative">
        <div class="h-6 bg-bg-sec border-b border-white/5 flex items-center px-4 gap-2">
          <div class="w-2.5 h-2.5 rounded-full bg-red-500/80"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/80"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-green-500/80"></div>
        </div>
        <div class="flex-1 p-5 flex gap-5">
          <div class="w-1/4 flex flex-col gap-3">
            <div class="h-4 w-full bg-white/10 rounded"></div>
            <div class="h-3 w-5/6 bg-white/5 rounded mt-4"></div>
            <div class="h-3 w-full bg-white/5 rounded"></div>
            <div class="h-3 w-4/5 bg-white/5 rounded"></div>
          </div>
          <div class="w-3/4 flex flex-col gap-4">
            <div class="flex gap-4">
              <div class="h-20 w-1/3 bg-gradient-to-br from-acc-blue/20 to-transparent border border-acc-blue/10 rounded-lg"></div>
              <div class="h-20 w-1/3 bg-gradient-to-br from-acc-violet/20 to-transparent border border-acc-violet/10 rounded-lg"></div>
              <div class="h-20 w-1/3 bg-white/5 rounded-lg border border-white/5"></div>
            </div>
            <div class="flex-1 bg-white/5 rounded-lg border border-white/5"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile mockup -->
    <div class="absolute right-[5%] bottom-[5%] w-[140px] h-[280px] bg-card-bg border-[4px] border-[#1E293B] rounded-[2rem] shadow-2xl z-20 animate-float-delayed">
      <div class="w-full h-full bg-bg-main rounded-[1.7rem] overflow-hidden relative">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/3 h-5 bg-[#1E293B] rounded-b-xl z-30"></div>
        <div class="h-1/2 bg-gradient-to-b from-acc-violet/10 to-bg-main p-4 pt-10 flex flex-col gap-3">
          <div class="h-3 w-1/2 bg-white/20 rounded"></div>
          <div class="flex-1 bg-white/5 rounded-xl border border-white/10"></div>
        </div>
        <div class="h-1/2 p-4 flex flex-col gap-3">
          <div class="h-12 w-full bg-white/5 rounded-lg"></div>
          <div class="h-12 w-full bg-white/5 rounded-lg"></div>
        </div>
      </div>
    </div>
  </div>
</section>
