---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
---
<section class="py-14 bg-bg-sec/40 border-y border-white/5 reveal">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-10 lg:gap-x-0 lg:divide-x lg:divide-white/10">
      <div class="lg:px-8 lg:first:pl-0">
        <div class="font-display text-4xl font-bold text-text-main leading-none">
          5<span class="text-accent">+</span>
          <span class="text-base font-medium text-text-sec ml-1">{t(lang, 'trust_years_label')}</span>
        </div>
        <p class="text-sm text-text-sec mt-3 leading-relaxed">{t(lang, 'trust_years_desc')}</p>
      </div>
      <div class="lg:px-8">
        <div class="font-display text-lg font-bold text-text-main leading-snug">{t(lang, 'trust_projects_title')}</div>
        <p class="text-sm text-text-sec mt-3 leading-relaxed">{t(lang, 'trust_projects_desc')}</p>
      </div>
      <div class="lg:px-8">
        <div class="font-display text-lg font-bold text-text-main leading-snug">{t(lang, 'trust_solutions_title')}</div>
        <p class="text-sm text-text-sec mt-3 leading-relaxed">{t(lang, 'trust_solutions_desc')}</p>
      </div>
      <div class="lg:px-8">
        <div class="font-display text-lg font-bold text-text-main leading-snug">{t(lang, 'trust_responsive_title')}</div>
        <p class="text-sm text-text-sec mt-3 leading-relaxed">{t(lang, 'trust_responsive_desc')}</p>
      </div>

    </div>
  </div>
</section>
