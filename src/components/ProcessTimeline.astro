---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import Section from './Section.astro';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
---
<Section id="proceso" padding="py-24">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="font-sora text-3xl md:text-4xl font-bold mb-6 text-white">{t(lang, 'process_title')}</h2>
      <p class="text-text-sec text-lg max-w-2xl mx-auto">{t(lang, 'process_subtitle')}</p>
    </div>

    <div class="relative">
      <div class="absolute left-[20px] md:left-1/2 md:-ml-[1px] top-0 bottom-0 w-[2px] bg-white/5"></div>

      <div class="space-y-12 relative z-10">
        <!-- Step 1 -->
        <div class="flex flex-col md:flex-row items-start md:items-center w-full">
          <div class="md:w-1/2 md:pr-12 md:text-right flex flex-col md:items-end pl-14 md:pl-0">
            <h3 class="font-sora text-xl font-bold text-white mb-2">{t(lang, 'process_step1_title')}</h3>
            <p class="text-sm text-text-sec">{t(lang, 'process_step1_desc')}</p>
          </div>
          <div class="absolute left-0 md:left-1/2 md:-ml-5 w-10 h-10 rounded-full bg-bg-sec border-2 border-white/20 flex items-center justify-center text-sm font-bold text-white shadow-lg">1</div>
          <div class="md:w-1/2 hidden md:block"></div>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col md:flex-row items-start md:items-center w-full">
          <div class="md:w-1/2 hidden md:block"></div>
          <div class="absolute left-0 md:left-1/2 md:-ml-5 w-10 h-10 rounded-full bg-bg-sec border-2 border-acc-blue flex items-center justify-center text-sm font-bold text-acc-blue shadow-[0_0_15px_rgba(56,189,248,0.2)]">2</div>
          <div class="md:w-1/2 md:pl-12 flex flex-col items-start pl-14 md:pl-12">
            <h3 class="font-sora text-xl font-bold text-white mb-2">{t(lang, 'process_step2_title')}</h3>
            <p class="text-sm text-text-sec">{t(lang, 'process_step2_desc')}</p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col md:flex-row items-start md:items-center w-full">
          <div class="md:w-1/2 md:pr-12 md:text-right flex flex-col md:items-end pl-14 md:pl-0">
            <h3 class="font-sora text-xl font-bold text-white mb-2">{t(lang, 'process_step3_title')}</h3>
            <p class="text-sm text-text-sec">{t(lang, 'process_step3_desc')}</p>
          </div>
          <div class="absolute left-0 md:left-1/2 md:-ml-5 w-10 h-10 rounded-full bg-bg-sec border-2 border-acc-violet flex items-center justify-center text-sm font-bold text-acc-violet shadow-[0_0_15px_rgba(139,92,246,0.2)]">3</div>
          <div class="md:w-1/2 hidden md:block"></div>
        </div>

        <!-- Step 4 -->
        <div class="flex flex-col md:flex-row items-start md:items-center w-full">
          <div class="md:w-1/2 hidden md:block"></div>
          <div class="absolute left-0 md:left-1/2 md:-ml-5 w-10 h-10 rounded-full bg-bg-sec border-2 border-acc-cyan flex items-center justify-center text-sm font-bold text-acc-cyan shadow-[0_0_15px_rgba(34,211,238,0.2)]">4</div>
          <div class="md:w-1/2 md:pl-12 flex flex-col items-start pl-14 md:pl-12">
            <h3 class="font-sora text-xl font-bold text-white mb-2">{t(lang, 'process_step4_title')}</h3>
            <p class="text-sm text-text-sec">{t(lang, 'process_step4_desc')}</p>
          </div>
        </div>

        <!-- Step 5 -->
        <div class="flex flex-col md:flex-row items-start md:items-center w-full">
          <div class="md:w-1/2 md:pr-12 md:text-right flex flex-col md:items-end pl-14 md:pl-0">
            <h3 class="font-sora text-xl font-bold text-white mb-2">{t(lang, 'process_step5_title')}</h3>
            <p class="text-sm text-text-sec">{t(lang, 'process_step5_desc')}</p>
          </div>
          <div class="absolute left-0 md:left-1/2 md:-ml-5 w-10 h-10 rounded-full bg-bg-sec border-2 border-green-400 flex items-center justify-center text-sm font-bold text-green-400 shadow-[0_0_15px_rgba(74,222,128,0.2)]">5</div>
          <div class="md:w-1/2 hidden md:block"></div>
        </div>
      </div>
    </div>
  </div>
</Section>
