---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import Section from './Section.astro';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;

const steps = [
  { title: 'process_step1_title', desc: 'process_step1_desc' },
  { title: 'process_step2_title', desc: 'process_step2_desc' },
  { title: 'process_step3_title', desc: 'process_step3_desc' },
  { title: 'process_step4_title', desc: 'process_step4_desc' },
  { title: 'process_step5_title', desc: 'process_step5_desc' },
];
---
<Section id="proceso" padding="py-24">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-5 text-text-main">{t(lang, 'process_title')}</h2>
      <p class="text-text-sec text-lg max-w-2xl mx-auto">{t(lang, 'process_subtitle')}</p>
    </div>

    <div class="relative">
      <div class="absolute left-[20px] md:left-1/2 md:-ml-px top-0 bottom-0 w-px bg-white/10"></div>

      <div class="space-y-12 relative z-10">
        {steps.map((step, i) => {
          const left = i % 2 === 0;
          const last = i === steps.length - 1;
          return (
            <div class="flex flex-col md:flex-row items-start md:items-center w-full">
              <div class={`md:w-1/2 ${left ? 'md:pr-12 md:text-right flex flex-col md:items-end pl-14 md:pl-0' : 'hidden md:block'}`}>
                {left && (
                  <Fragment>
                    <h3 class="font-display text-xl font-bold text-text-main mb-2">{t(lang, step.title)}</h3>
                    <p class="text-sm text-text-sec max-w-sm">{t(lang, step.desc)}</p>
                  </Fragment>
                )}
              </div>

              <div class={`absolute left-0 md:left-1/2 md:-ml-5 w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold ${last ? 'bg-accent border-2 border-accent text-bg-main' : 'bg-bg-sec border-2 border-accent/40 text-accent'}`}>
                {i + 1}
              </div>

              <div class={`md:w-1/2 ${!left ? 'md:pl-12 flex flex-col items-start pl-14 md:pl-12' : 'hidden md:block'}`}>
                {!left && (
                  <Fragment>
                    <h3 class="font-display text-xl font-bold text-text-main mb-2">{t(lang, step.title)}</h3>
                    <p class="text-sm text-text-sec max-w-sm">{t(lang, step.desc)}</p>
                  </Fragment>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</Section>
