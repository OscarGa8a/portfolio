---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
---
<nav class="fixed w-full z-50 glass-nav transition-all duration-300 py-4">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 flex justify-between items-center">
    <a href={lang === 'es' ? '/' : '/en/'} class="font-sora font-bold text-xl tracking-tight flex items-center gap-2.5 group">
      <div class="w-8 h-8 rounded-lg bg-gradient-primary flex items-center justify-center text-sm shadow-[0_0_15px_rgba(56,189,248,0.3)] group-hover:shadow-[0_0_20px_rgba(139,92,246,0.5)] transition-all">
        <span class="text-white font-bold">OG</span>
      </div>
      <span class="text-text-main">Oscar García <span class="text-text-sec font-normal">Dev</span></span>
    </a>

    <div class="hidden md:flex items-center space-x-8 text-sm font-medium text-text-sec">
      <a href="#especialidades" class="hover:text-text-main transition-colors">{t(lang, 'nav_specialties')}</a>
      <a href="#casos" class="hover:text-text-main transition-colors">{t(lang, 'nav_case_studies')}</a>
      <a href="#proceso" class="hover:text-text-main transition-colors">{t(lang, 'nav_process')}</a>
      <a href="#sobre-mi" class="hover:text-text-main transition-colors">{t(lang, 'nav_about')}</a>
    </div>

    <div class="flex items-center space-x-4">
      <LanguageToggle lang={lang} />
      <a href="#contacto" class="hidden md:inline-flex bg-white text-bg-main px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-gray-200 transition-all shadow-lg">
        {t(lang, 'nav_cta')}
      </a>
    </div>
  </div>
</nav>
