---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import { Icon } from 'astro-icon/components';
import { contact } from '../config/site';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const year = new Date().getFullYear();
const tagline = lang === 'es'
  ? 'Webs, e-commerce, apps y plataformas a medida.'
  : 'Websites, e-commerce, apps and custom platforms.';
---
<footer class="border-t border-white/5 bg-bg-sec/80 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8 mb-12">
      <div class="text-center md:text-left">
        <a href={lang === 'es' ? '/' : '/en/'} class="font-display font-bold text-xl tracking-tight flex items-center justify-center md:justify-start gap-2 mb-2">
          <div class="w-6 h-6 rounded bg-gradient-primary flex items-center justify-center text-[10px] text-bg-main font-bold">OG</div>
          <span class="text-text-main">Oscar García <span class="text-text-sec font-normal">Dev</span></span>
        </a>
        <p class="text-text-sec text-sm">{tagline}</p>
      </div>

      <div class="flex flex-wrap justify-center gap-6 text-sm text-text-sec font-medium">
        <a href="#especialidades" class="hover:text-text-main transition-colors">{t(lang, 'footer_specialties')}</a>
        <a href="#casos" class="hover:text-text-main transition-colors">{t(lang, 'footer_case_studies')}</a>
        <a href="#proceso" class="hover:text-text-main transition-colors">{t(lang, 'footer_process')}</a>
        <a href="#sobre-mi" class="hover:text-text-main transition-colors">{t(lang, 'footer_about')}</a>
      </div>

      <div class="flex gap-4">
        <a href={contact.linkedin} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-text-sec hover:text-accent hover:border-accent/40 transition-colors" aria-label="LinkedIn">
          <Icon name="ph:linkedin-logo" class="w-5 h-5" />
        </a>
        <a href={contact.github} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-text-sec hover:text-accent hover:border-accent/40 transition-colors" aria-label="GitHub">
          <Icon name="ph:github-logo" class="w-5 h-5" />
        </a>
      </div>
    </div>

    <div class="text-center text-sm text-text-sec/60 pt-8 border-t border-white/5">
      &copy; {year} Oscar García Dev. {t(lang, 'footer_rights')}
    </div>
  </div>
</footer>
