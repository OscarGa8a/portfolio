---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="border-t border-white/5 bg-bg-sec/80 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8 mb-12">
      <div class="text-center md:text-left">
        <a href={lang === 'es' ? '/' : '/en/'} class="font-sora font-bold text-xl tracking-tight flex items-center justify-center md:justify-start gap-2 mb-2">
          <div class="w-6 h-6 rounded bg-gradient-primary flex items-center justify-center text-[10px] text-white">JD</div>
          <span class="text-text-main">Juan David <span class="text-text-sec font-normal">Studio</span></span>
        </a>
        <p class="text-text-sec text-sm">Websites · E-commerce · Apps · {t(lang, 'footer_tagline')}</p>
      </div>

      <div class="flex flex-wrap justify-center gap-6 text-sm text-text-sec font-medium">
        <a href="#especialidades" class="hover:text-text-main transition-colors">{t(lang, 'footer_specialties')}</a>
        <a href="#casos" class="hover:text-text-main transition-colors">{t(lang, 'footer_case_studies')}</a>
        <a href="#proceso" class="hover:text-text-main transition-colors">{t(lang, 'footer_process')}</a>
        <a href="#sobre-mi" class="hover:text-text-main transition-colors">{t(lang, 'footer_about')}</a>
      </div>

      <div class="flex gap-4">
        <a href="#" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-text-sec hover:text-text-main hover:bg-white/10 transition-all" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </a>
        <a href="#" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-text-sec hover:text-text-main hover:bg-white/10 transition-all" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>

    <div class="text-center text-sm text-text-sec/60 pt-8 border-t border-white/5">
      &copy; {year} Juan David Studio. {t(lang, 'footer_rights')}
    </div>
  </div>
</footer>
