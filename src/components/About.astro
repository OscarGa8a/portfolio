---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import Section from './Section.astro';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
---
<Section id="sobre-mi" bg="bg-bg-sec/30 border-y border-white/5" padding="py-24">
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center gap-16">
    <!-- Profile card -->
    <div class="w-full lg:w-5/12 flex justify-center">
      <div class="relative w-72 h-80 premium-card rounded-[2rem] p-6 flex flex-col items-center justify-center border border-white/10 shadow-2xl rotate-2 hover:rotate-0 transition-transform duration-500">
        <div class="absolute -top-4 -right-4 w-24 h-24 bg-acc-blue/20 rounded-full blur-[40px] z-0"></div>
        <div class="absolute -bottom-4 -left-4 w-24 h-24 bg-acc-violet/20 rounded-full blur-[40px] z-0"></div>

        <div class="w-24 h-24 rounded-full bg-gradient-primary flex items-center justify-center text-3xl font-bold text-white mb-6 shadow-xl relative z-10">
          OG
        </div>
        <h3 class="font-sora text-xl font-bold text-white mb-1 relative z-10">Oscar García</h3>
        <p class="text-sm text-text-sec uppercase tracking-widest relative z-10">Dev</p>

        <div class="mt-8 flex gap-3 relative z-10">
          <div class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/50">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </div>
          <div class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/50">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="w-full lg:w-7/12">
      <h2 class="font-sora text-3xl md:text-4xl font-bold mb-6 text-white">{t(lang, 'about_title')}</h2>
      <p class="text-text-sec text-lg leading-relaxed mb-8">{t(lang, 'about_body')}</p>

      <div class="flex flex-wrap gap-3">
        <span class="bg-white/5 border border-white/10 px-3.5 py-1.5 rounded-md text-sm text-white/90 shadow-sm">{t(lang, 'about_tag_webdev')}</span>
        <span class="bg-white/5 border border-white/10 px-3.5 py-1.5 rounded-md text-sm text-white/90 shadow-sm">{t(lang, 'about_tag_responsive')}</span>
        <span class="bg-white/5 border border-white/10 px-3.5 py-1.5 rounded-md text-sm text-white/90 shadow-sm">{t(lang, 'about_tag_products')}</span>
        <span class="bg-white/5 border border-white/10 px-3.5 py-1.5 rounded-md text-sm text-white/90 shadow-sm">{t(lang, 'about_tag_solutions')}</span>
        <span class="bg-white/5 border border-white/10 px-3.5 py-1.5 rounded-md text-sm text-white/90 shadow-sm">{t(lang, 'about_tag_freelance')}</span>
      </div>
    </div>
  </div>
</Section>
