---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import { Icon } from 'astro-icon/components';
import Section from './Section.astro';
import { contact } from '../config/site';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;

const tags = [
  'about_tag_webdev',
  'about_tag_responsive',
  'about_tag_products',
  'about_tag_solutions',
  'about_tag_freelance',
];
---
<Section id="sobre-mi" bg="bg-bg-sec/30 border-y border-white/5" padding="py-24">
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center gap-16">
    <!-- Profile card -->
    <div class="w-full lg:w-5/12 flex justify-center">
      <div class="relative w-72 h-80 premium-card rounded-[2rem] flex flex-col items-center justify-center border border-white/10 shadow-2xl rotate-2 hover:rotate-0 transition-transform duration-500 overflow-hidden">
        <div class="absolute -top-8 -right-8 w-32 h-32 bg-accent/15 rounded-full blur-[44px] pointer-events-none"></div>

        <!-- TODO: replace this monogram block with a real photo:
             <img src="/img/oscar.webp" alt="Oscar García" class="absolute inset-0 w-full h-full object-cover" /> -->
        <div class="w-24 h-24 rounded-full bg-gradient-primary flex items-center justify-center text-3xl font-bold text-bg-main mb-6 shadow-xl relative z-10">
          OG
        </div>
        <h3 class="font-display text-xl font-bold text-text-main mb-1 relative z-10">Oscar García</h3>
        <p class="text-sm text-text-sec uppercase tracking-widest relative z-10">Dev</p>

        <div class="mt-8 flex gap-3 relative z-10">
          <a href={contact.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-text-sec hover:text-accent hover:border-accent/40 transition-colors">
            <Icon name="ph:linkedin-logo" class="w-4 h-4" />
          </a>
          <a href={contact.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-text-sec hover:text-accent hover:border-accent/40 transition-colors">
            <Icon name="ph:github-logo" class="w-4 h-4" />
          </a>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="w-full lg:w-7/12">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-6 text-text-main">{t(lang, 'about_title')}</h2>
      <p class="text-text-sec text-lg leading-relaxed mb-8">{t(lang, 'about_body')}</p>

      <div class="flex flex-wrap gap-3">
        {tags.map((tag) => (
          <span class="bg-white/5 border border-white/10 px-3.5 py-1.5 rounded-md text-sm text-text-main/90">{t(lang, tag)}</span>
        ))}
      </div>
    </div>
  </div>
</Section>
