---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import Section from './Section.astro';
import CaseStudyCard from './CaseStudyCard.astro';

interface Props { lang: Locale; }
const { lang } = Astro.props;
---
<section id="casos" class="py-24 bg-bg-sec/30 border-y border-white/5 reveal">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="font-sora text-3xl md:text-4xl font-bold mb-6 text-white">{t(lang, 'cases_title')}</h2>
      <p class="text-text-sec text-lg">{t(lang, 'cases_subtitle')}</p>
    </div>

    <div class="space-y-12">
      <!-- ConectaPlay -->
      <CaseStudyCard
        lang={lang}
        title="ConectaPlay"
        tagKey="cases_tag_sports"
        tagColor="#22D3EE"
        descKey="cases_conectaplay_desc"
        features={['cases_conectaplay_f1', 'cases_conectaplay_f2', 'cases_conectaplay_f3']}
        problemKey="cases_conectaplay_problem"
        solutionKey="cases_conectaplay_solution"
        resultKey="cases_conectaplay_result"
        resultColor="#22D3EE"
        ctaLabelKey="cases_visit_web"
        variant="image-left"
      >
        <div slot="mockup" class="w-full aspect-[4/3] bg-card-bg border border-white/10 rounded-xl relative shadow-2xl flex flex-col overflow-hidden">
          <div class="h-8 bg-[#1E293B] flex items-center px-3 border-b border-white/5"><div class="w-16 h-3 bg-white/10 rounded"></div></div>
          <div class="flex-1 p-4 flex gap-4">
            <div class="w-1/3 bg-white/5 rounded-lg border border-white/5"></div>
            <div class="w-2/3 flex flex-col gap-2">
              <div class="h-24 bg-acc-cyan/10 rounded-lg border border-acc-cyan/20"></div>
              <div class="flex-1 bg-white/5 rounded-lg border border-white/5"></div>
            </div>
          </div>
        </div>
      </CaseStudyCard>

      <!-- DeTour -->
      <CaseStudyCard
        lang={lang}
        title="DeTour"
        tagKey="cases_tag_tourism"
        tagColor="#8B5CF6"
        descKey="cases_detour_desc"
        features={['cases_detour_f1', 'cases_detour_f2', 'cases_detour_f3']}
        problemKey="cases_detour_problem"
        solutionKey="cases_detour_solution"
        resultKey="cases_detour_result"
        resultColor="#8B5CF6"
        ctaLabelKey="cases_visit_play"
        variant="image-right"
      >
        <div slot="mockup" class="w-48 h-80 bg-card-bg border-[4px] border-[#1E293B] rounded-[2rem] relative shadow-2xl flex flex-col overflow-hidden">
          <div class="h-1/2 bg-gradient-to-b from-acc-violet/20 to-transparent p-4 flex flex-col gap-2 justify-end"><div class="h-16 w-full bg-white/5 border border-white/10 rounded-lg"></div></div>
          <div class="flex-1 p-4 flex flex-col gap-3"><div class="h-10 w-full bg-white/5 rounded-lg"></div><div class="h-10 w-full bg-white/5 rounded-lg"></div></div>
        </div>
      </CaseStudyCard>

      <!-- Fuera del Molde -->
      <CaseStudyCard
        lang={lang}
        title="Fuera del Molde"
        tagKey="cases_tag_ecom"
        tagColor="#F472B6"
        descKey="cases_fueradelMolde_desc"
        features={['cases_fueradelMolde_f1', 'cases_fueradelMolde_f2', 'cases_fueradelMolde_f3']}
        problemKey="cases_fueradelMolde_problem"
        solutionKey="cases_fueradelMolde_solution"
        resultKey="cases_fueradelMolde_result"
        resultColor="#F472B6"
        ctaLabelKey="cases_visit_store"
        variant="image-left"
      >
        <div slot="mockup" class="w-full aspect-[4/3] bg-card-bg border border-white/10 rounded-xl relative shadow-2xl flex flex-col overflow-hidden p-4">
          <div class="flex justify-between border-b border-white/10 pb-3 mb-4"><div class="w-1/4 h-3 bg-white/20 rounded"></div><div class="w-8 h-8 rounded-full bg-white/10"></div></div>
          <div class="grid grid-cols-2 gap-3 flex-1">
            <div class="bg-white/5 rounded border border-white/5"></div>
            <div class="bg-white/5 rounded border border-white/5"></div>
          </div>
        </div>
      </CaseStudyCard>

      <!-- La Locura Bar -->
      <CaseStudyCard
        lang={lang}
        title="La Locura Bar"
        tagKey="cases_tag_bar"
        tagColor="#FACC15"
        descKey="cases_locuraBar_desc"
        features={['cases_locuraBar_f1', 'cases_locuraBar_f2', 'cases_locuraBar_f3']}
        problemKey="cases_locuraBar_problem"
        solutionKey="cases_locuraBar_solution"
        resultKey="cases_locuraBar_result"
        resultColor="#FACC15"
        ctaLabelKey="cases_visit_web"
        variant="image-right"
      >
        <div slot="mockup" class="w-full aspect-[4/3] bg-card-bg border border-white/10 rounded-xl relative shadow-2xl flex flex-col overflow-hidden">
          <div class="h-20 bg-gradient-to-b from-yellow-500/20 to-transparent"></div>
          <div class="flex-1 p-4 flex flex-col justify-center items-center gap-4">
            <div class="w-20 h-20 rounded-full border-4 border-white/10 bg-white/5"></div>
            <div class="h-4 w-1/3 bg-white/20 rounded"></div>
            <div class="h-8 w-1/2 bg-yellow-500/20 rounded border border-yellow-500/30"></div>
          </div>
        </div>
      </CaseStudyCard>
    </div>

    <!-- Secondary Projects -->
    <div class="mt-16 pt-16 border-t border-white/5">
      <h3 class="font-sora text-xl font-bold mb-8 text-white">{t(lang, 'cases_more_title')}</h3>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="premium-card p-6 rounded-2xl flex items-center justify-between">
          <div>
            <h4 class="font-sora font-bold text-white mb-1">CIA Vial del Llano</h4>
            <p class="text-sm text-text-sec">{t(lang, 'cases_cia_type')}</p>
          </div>
          <a href="#" class="text-acc-blue hover:text-white transition-colors p-2 bg-white/5 rounded-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
          </a>
        </div>
        <div class="premium-card p-6 rounded-2xl flex items-center justify-between">
          <div>
            <h4 class="font-sora font-bold text-white mb-1">DeTour Cundinamarca Web</h4>
            <p class="text-sm text-text-sec">{t(lang, 'cases_detour_web_type')}</p>
          </div>
          <a href="#" class="text-acc-violet hover:text-white transition-colors p-2 bg-white/5 rounded-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
