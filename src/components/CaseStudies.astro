---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import CaseStudyCard from './CaseStudyCard.astro';
import duartes from '../assets/projects/duartes.png';
import conectaplay from '../assets/projects/conectaplay.png';
import detour from '../assets/projects/detour.png';
import fueradelmolde from '../assets/projects/fueradelmolde.png';
import lalocura from '../assets/projects/lalocura.png';

interface Props { lang: Locale; }
const { lang } = Astro.props;
---
<section id="casos" class="py-24 bg-bg-sec/30 border-y border-white/5 reveal">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-3xl mb-12">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-5 text-text-main">{t(lang, 'cases_title')}</h2>
      <p class="text-text-sec text-lg">{t(lang, 'cases_subtitle')}</p>
    </div>

    <div class="divide-y divide-white/10 border-t border-white/10">
      <!-- Duarte's Auto Detailing (flagship · US client) -->
      <div class="py-14 first:pt-12">
        <CaseStudyCard
          lang={lang}
          title="Duarte's Auto Detailing"
          tagKey="cases_tag_detailing"
          descKey="cases_duartes_desc"
          features={['cases_duartes_f1', 'cases_duartes_f2', 'cases_duartes_f3']}
          problemKey="cases_duartes_problem"
          solutionKey="cases_duartes_solution"
          resultKey="cases_duartes_result"
          ctaLabelKey="cases_visit_web"
          ctaHref="https://duartesautodetailing.com/"
          variant="image-right"
        >
          <Image
            slot="mockup"
            src={duartes}
            alt={lang === 'es' ? "Duarte's Auto Detailing — landing de detailing premium a domicilio" : "Duarte's Auto Detailing — premium mobile detailing landing"}
            class="w-full aspect-[4/3] object-cover object-top rounded-xl border border-white/10"
          />
        </CaseStudyCard>
      </div>

      <!-- ConectaPlay -->
      <div class="py-14">
        <CaseStudyCard
          lang={lang}
          title="ConectaPlay"
          tagKey="cases_tag_sports"
          descKey="cases_conectaplay_desc"
          features={['cases_conectaplay_f1', 'cases_conectaplay_f2', 'cases_conectaplay_f3']}
          problemKey="cases_conectaplay_problem"
          solutionKey="cases_conectaplay_solution"
          resultKey="cases_conectaplay_result"
          ctaLabelKey="cases_visit_web"
          ctaHref="https://app.conectaplay.co/"
          variant="image-left"
        >
          <Image
            slot="mockup"
            src={conectaplay}
            alt={lang === 'es' ? 'ConectaPlay — plataforma de gestión deportiva' : 'ConectaPlay — sports management platform'}
            class="w-full aspect-[4/3] object-cover object-top rounded-xl border border-white/10"
          />
        </CaseStudyCard>
      </div>

      <!-- DeTour -->
      <div class="py-14">
        <CaseStudyCard
          lang={lang}
          title="DeTour"
          tagKey="cases_tag_tourism"
          descKey="cases_detour_desc"
          features={['cases_detour_f1', 'cases_detour_f2', 'cases_detour_f3']}
          problemKey="cases_detour_problem"
          solutionKey="cases_detour_solution"
          resultKey="cases_detour_result"
          links={[
            { label: 'Google Play', href: 'https://play.google.com/store/apps/details?id=com.GrupoCato.DeTourCundi' },
            { label: 'App Store', href: 'https://apps.apple.com/us/app/de-tour-por-cundinamarca/id1488257160' },
          ]}
          variant="image-right"
        >
          <Image
            slot="mockup"
            src={detour}
            alt={lang === 'es' ? 'DeTour — turismo VR por Cundinamarca' : 'DeTour — VR tourism in Cundinamarca'}
            class="w-48 aspect-[9/16] object-cover object-top rounded-[2rem] border border-white/10"
          />
        </CaseStudyCard>
      </div>

      <!-- Fuera del Molde -->
      <div class="py-14">
        <CaseStudyCard
          lang={lang}
          title="Fuera del Molde"
          tagKey="cases_tag_ecom"
          descKey="cases_fueradelMolde_desc"
          features={['cases_fueradelMolde_f1', 'cases_fueradelMolde_f2', 'cases_fueradelMolde_f3']}
          problemKey="cases_fueradelMolde_problem"
          solutionKey="cases_fueradelMolde_solution"
          resultKey="cases_fueradelMolde_result"
          ctaLabelKey="cases_visit_store"
          ctaHref="https://fueradelmolde.com/"
          variant="image-left"
        >
          <Image
            slot="mockup"
            src={fueradelmolde}
            alt={lang === 'es' ? 'Fuera del Molde — e-commerce de productos personalizados' : 'Fuera del Molde — custom products e-commerce'}
            class="w-full aspect-[4/3] object-cover object-top rounded-xl border border-white/10"
          />
        </CaseStudyCard>
      </div>

      <!-- La Locura Bar -->
      <div class="py-14">
        <CaseStudyCard
          lang={lang}
          title="La Locura Bar"
          tagKey="cases_tag_bar"
          descKey="cases_locuraBar_desc"
          features={['cases_locuraBar_f1', 'cases_locuraBar_f2', 'cases_locuraBar_f3']}
          problemKey="cases_locuraBar_problem"
          solutionKey="cases_locuraBar_solution"
          resultKey="cases_locuraBar_result"
          ctaLabelKey="cases_visit_web"
          ctaHref="https://lalocurabar.com.co/"
          variant="image-right"
        >
          <Image
            slot="mockup"
            src={lalocura}
            alt={lang === 'es' ? 'La Locura Bar — sitio web del bar' : 'La Locura Bar — bar website'}
            class="w-full aspect-[4/3] object-cover object-top rounded-xl border border-white/10"
          />
        </CaseStudyCard>
      </div>
    </div>

    <!-- Secondary projects: plain list, no boxes -->
    <div class="mt-14 pt-12 border-t border-white/10">
      <h3 class="font-display text-xl font-bold mb-4 text-text-main">{t(lang, 'cases_more_title')}</h3>
      <div class="divide-y divide-white/10">
        <a href="https://ciavialdelllano.com.co/" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between py-5 group">
          <div>
            <h4 class="font-display font-bold text-text-main group-hover:text-accent transition-colors">CIA Vial del Llano</h4>
            <p class="text-sm text-text-sec mt-0.5">{t(lang, 'cases_cia_type')}</p>
          </div>
          <Icon name="ph:arrow-up-right" class="w-5 h-5 text-text-sec group-hover:text-accent transition-colors shrink-0" />
        </a>
        <a href="https://detour.cundinamarca.gov.co/" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between py-5 group">
          <div>
            <h4 class="font-display font-bold text-text-main group-hover:text-accent transition-colors">DeTour Cundinamarca Web</h4>
            <p class="text-sm text-text-sec mt-0.5">{t(lang, 'cases_detour_web_type')}</p>
          </div>
          <Icon name="ph:arrow-up-right" class="w-5 h-5 text-text-sec group-hover:text-accent transition-colors shrink-0" />
        </a>
      </div>
    </div>
  </div>
</section>
