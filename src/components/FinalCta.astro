---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import { Icon } from 'astro-icon/components';
import { contact } from '../config/site';

interface Props { lang: Locale; }
const { lang } = Astro.props;
---
<section id="contacto" class="py-28 relative reveal overflow-hidden">
  <!-- Accent glow does the focusing, no card box -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[640px] max-w-[90vw] h-[420px] bg-accent/10 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center relative">
    <h2 class="font-display text-3xl md:text-5xl font-bold mb-6 text-text-main leading-tight">
      {t(lang, 'cta_title')}
    </h2>
    <p class="text-text-sec text-lg mb-10 max-w-2xl mx-auto">
      {t(lang, 'cta_subtitle')}
    </p>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href={contact.whatsapp} target="_blank" rel="noopener noreferrer" class="bg-accent text-bg-main px-8 py-4 rounded-xl font-bold hover:bg-accent-strong transition-colors active:translate-y-px flex items-center justify-center gap-2">
        <Icon name="ph:whatsapp-logo" class="w-5 h-5" />
        {t(lang, 'cta_whatsapp')}
      </a>
      <a href={contact.email} class="bg-white/5 hover:bg-white/10 border border-white/10 px-8 py-4 rounded-xl font-bold text-text-main transition-colors active:translate-y-px flex items-center justify-center gap-2">
        <Icon name="ph:envelope-simple" class="w-5 h-5" />
        {t(lang, 'cta_email')}
      </a>
    </div>
  </div>
</section>
