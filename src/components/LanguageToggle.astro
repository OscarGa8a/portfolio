---
import type { Locale } from '../i18n/index';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const dest = lang === 'es' ? '/en/' : '/';
const label = lang === 'es' ? 'EN' : 'ES';
---
<a
  href={dest}
  class="text-xs font-bold text-text-sec hover:text-text-main transition-colors bg-white/5 border border-white/10 px-3 py-1.5 rounded-md flex items-center gap-1.5"
  aria-label={`Switch to ${label}`}
>
  <svg class="w-3.5 h-3.5 text-acc-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
  </svg>
  {label}
</a>
