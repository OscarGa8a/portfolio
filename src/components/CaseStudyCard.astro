---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';

interface Props {
  lang: Locale;
  title: string;
  tagKey: string;
  tagColor: string;
  descKey: string;
  features: string[];
  problemKey: string;
  solutionKey: string;
  resultKey: string;
  resultColor: string;
  ctaLabelKey: string;
  ctaHref?: string;
  variant?: 'image-left' | 'image-right';
}

const {
  lang,
  title,
  tagKey,
  tagColor,
  descKey,
  features,
  problemKey,
  solutionKey,
  resultKey,
  resultColor,
  ctaLabelKey,
  ctaHref = '#',
  variant = 'image-left',
} = Astro.props;

const isRight = variant === 'image-right';
---
<div class={`premium-card rounded-3xl overflow-hidden flex flex-col ${isRight ? 'lg:flex-row-reverse' : 'lg:flex-row'}`}>
  <!-- Mockup slot -->
  <div class={`lg:w-5/12 bg-bg-main relative overflow-hidden flex items-center justify-center p-8 border-b lg:border-b-0 ${isRight ? 'lg:border-l' : 'lg:border-r'} border-white/5`}>
    <slot name="mockup" />
  </div>

  <!-- Content -->
  <div class="lg:w-7/12 p-8 lg:p-10 flex flex-col justify-center">
    <div class="text-xs font-semibold tracking-wider uppercase mb-3" style={`color: ${tagColor}`}>
      {t(lang, tagKey)}
    </div>
    <h3 class="font-sora text-2xl lg:text-3xl font-bold mb-4 text-white">{title}</h3>
    <p class="text-text-sec mb-6">{t(lang, descKey)}</p>

    <div class="flex gap-4 mb-8">
      <div class="flex flex-col gap-1">
        <span class="text-white text-sm font-semibold">{lang === 'es' ? 'Características' : 'Features'}</span>
        <ul class="space-y-1 mt-1">
          {features.map(k => (
            <li class="text-xs text-text-sec flex items-center gap-1.5">
              <span style={`color: ${tagColor}`}>✓</span> {t(lang, k)}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <details class="group bg-white/5 border border-white/10 rounded-xl mb-6">
      <summary class="p-4 font-semibold text-sm text-white flex justify-between items-center hover:bg-white/5 transition-colors rounded-xl outline-none cursor-pointer">
        <span>{t(lang, 'cases_study_label')}</span>
        <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" style={`color: ${tagColor}`}><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </summary>
      <div class="p-5 pt-2 text-sm text-text-sec space-y-4 border-t border-white/10">
        <div><strong class="text-white block mb-1">{t(lang, 'cases_problem_label')}</strong>{t(lang, problemKey)}</div>
        <div><strong class="text-white block mb-1">{t(lang, 'cases_solution_label')}</strong>{t(lang, solutionKey)}</div>
        <div><strong class="text-white block mb-1">{t(lang, 'cases_result_label')}</strong><span style={`color: ${resultColor}`}>{t(lang, resultKey)}</span></div>
      </div>
    </details>

    <div>
      <a href={ctaHref} class="inline-flex items-center gap-2 text-sm font-semibold text-bg-main bg-white px-5 py-2.5 rounded-lg hover:bg-gray-200 transition-colors">
        {t(lang, ctaLabelKey)}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
      </a>
    </div>
  </div>
</div>
