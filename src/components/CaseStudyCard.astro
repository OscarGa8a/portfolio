---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import { Icon } from 'astro-icon/components';

interface Props {
  lang: Locale;
  title: string;
  tagKey: string;
  descKey: string;
  features: string[];
  problemKey: string;
  solutionKey: string;
  resultKey: string;
  ctaLabelKey?: string;
  ctaHref?: string;
  // For projects that live in more than one place (e.g. an app on both stores).
  links?: { label: string; href: string }[];
  variant?: 'image-left' | 'image-right';
}

const {
  lang,
  title,
  tagKey,
  descKey,
  features,
  problemKey,
  solutionKey,
  resultKey,
  ctaLabelKey,
  ctaHref = '#',
  links,
  variant = 'image-left',
} = Astro.props;

const isRight = variant === 'image-right';
const hasMultiple = Array.isArray(links) && links.length > 0;
---
<div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
  <!-- Preview (single framed image, no surrounding card) -->
  <div class={`relative flex justify-center ${isRight ? 'lg:order-2' : ''}`}>
    <div class="absolute inset-x-12 inset-y-6 bg-accent/10 blur-[80px] rounded-full pointer-events-none -z-10"></div>
    <slot name="mockup" />
  </div>

  <!-- Content -->
  <div class={isRight ? 'lg:order-1' : ''}>
    <div class="text-xs font-semibold tracking-wide uppercase text-accent mb-3">{t(lang, tagKey)}</div>
    <h3 class="font-display text-2xl lg:text-3xl font-bold mb-4 text-text-main">{title}</h3>
    <p class="text-text-sec leading-relaxed mb-6">{t(lang, descKey)}</p>

    <ul class="flex flex-wrap gap-x-5 gap-y-2 mb-7">
      {features.map((k) => (
        <li class="text-sm text-text-sec flex items-center gap-1.5">
          <Icon name="ph:check" class="w-4 h-4 text-accent shrink-0" /> {t(lang, k)}
        </li>
      ))}
    </ul>

    <details class="group border-t border-white/10 pt-4 mb-6">
      <summary class="flex justify-between items-center cursor-pointer text-sm font-semibold text-text-main list-none">
        <span>{t(lang, 'cases_study_label')}</span>
        <Icon name="ph:caret-down" class="w-4 h-4 text-accent transition-transform group-open:rotate-180" />
      </summary>
      <div class="pt-4 text-sm text-text-sec space-y-4">
        <div><strong class="text-text-main block mb-1">{t(lang, 'cases_problem_label')}</strong>{t(lang, problemKey)}</div>
        <div><strong class="text-text-main block mb-1">{t(lang, 'cases_solution_label')}</strong>{t(lang, solutionKey)}</div>
        <div><strong class="text-text-main block mb-1">{t(lang, 'cases_result_label')}</strong><span class="text-accent">{t(lang, resultKey)}</span></div>
      </div>
    </details>

    {hasMultiple ? (
      <div class="flex flex-wrap gap-x-6 gap-y-3">
        {links!.map((l) => (
          <a href={l.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-semibold text-accent hover:text-accent-strong transition-colors">
            {l.label}
            <Icon name="ph:arrow-up-right" class="w-4 h-4" />
          </a>
        ))}
      </div>
    ) : (
      <a href={ctaHref} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-semibold text-accent hover:text-accent-strong transition-colors">
        {t(lang, ctaLabelKey!)}
        <Icon name="ph:arrow-up-right" class="w-4 h-4" />
      </a>
    )}
  </div>
</div>
