---
import '../styles/global.css';
import RevealObserver from '../components/RevealObserver.astro';

interface Props {
  lang: 'es' | 'en';
  title?: string;
  description?: string;
}
const {
  lang,
  title = 'Oscar García Dev | Freelance Web Developer',
  description = lang === 'es'
    ? 'Desarrollador web freelance: sitios web, e-commerce, apps y plataformas a medida para negocios reales.'
    : 'Freelance web developer: websites, e-commerce, apps and custom platforms for real businesses.',
} = Astro.props;
---
<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="alternate" hreflang="es" href="/" />
    <link rel="alternate" hreflang="en" href="/en/" />
    <link rel="alternate" hreflang="x-default" href="/" />
  </head>
  <body class="antialiased">
    <slot />
    <RevealObserver />
  </body>
</html>
